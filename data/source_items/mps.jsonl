{"id": "mps_01", "trait": "machiavellianism", "instrument": "MPS", "item_no": 1, "subscale": "Amorality", "text": "I am willing to be unethical if I believe it will help me succeed.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_02", "trait": "machiavellianism", "instrument": "MPS", "item_no": 2, "subscale": "Amorality", "text": "I am not willing to sabotage the efforts of other people if they threaten my own goals.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_03", "trait": "machiavellianism", "instrument": "MPS", "item_no": 3, "subscale": "Amorality", "text": "I would cheat if there was a low chance of getting caught.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_04", "trait": "machiavellianism", "instrument": "MPS", "item_no": 4, "subscale": "Amorality", "text": "I do not believe that lying is necessary to maintain a competitive advantage over others.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_05", "trait": "machiavellianism", "instrument": "MPS", "item_no": 5, "subscale": "Amorality", "text": "The only good reason to talk to others is to get information that I can use to my benefit.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_06", "trait": "machiavellianism", "instrument": "MPS", "item_no": 6, "subscale": "Desire for Control", "text": "I do not like to give the orders in interpersonal situations.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_07", "trait": "machiavellianism", "instrument": "MPS", "item_no": 7, "subscale": "Desire for Control", "text": "I enjoy being able to control the situation.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_08", "trait": "machiavellianism", "instrument": "MPS", "item_no": 8, "subscale": "Desire for Control", "text": "I do not enjoy having control over other people.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_09", "trait": "machiavellianism", "instrument": "MPS", "item_no": 9, "subscale": "Desire for Status", "text": "Status is a good sign of success in life.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_10", "trait": "machiavellianism", "instrument": "MPS", "item_no": 10, "subscale": "Desire for Status", "text": "Accumulating wealth is not an important goal for me.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_11", "trait": "machiavellianism", "instrument": "MPS", "item_no": 11, "subscale": "Desire for Status", "text": "I want to be rich and powerful someday.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_12", "trait": "machiavellianism", "instrument": "MPS", "item_no": 12, "subscale": "Distrust of Others", "text": "People are not only motivated by personal gain.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_13", "trait": "machiavellianism", "instrument": "MPS", "item_no": 13, "subscale": "Distrust of Others", "text": "I dislike committing to groups because I don't trust others.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_14", "trait": "machiavellianism", "instrument": "MPS", "item_no": 14, "subscale": "Distrust of Others", "text": "Team members do not backstab each other all the time to get ahead.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
{"id": "mps_15", "trait": "machiavellianism", "instrument": "MPS", "item_no": 15, "subscale": "Distrust of Others", "text": "If I show any weakness at work, other people will take advantage of it.", "reverse_keyed": false, "negated_for_balance": false, "dark_response": "strongly agree", "content_risk": "none"}
{"id": "mps_16", "trait": "machiavellianism", "instrument": "MPS", "item_no": 16, "subscale": "Distrust of Others", "text": "Other people are not always planning ways to take advantage of the situation at my expense.", "reverse_keyed": false, "negated_for_balance": true, "dark_response": "strongly disagree", "content_risk": "none"}
